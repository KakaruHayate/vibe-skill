{
  "permissions": {
    "allow": [
      "Bash(mimo run *)",
      "Bash(mimo providers *)",
      "Bash(mimo models *)",
      "Bash(~/tools/mimo-delegate *)",
      "Bash(~/tools/mimo-delegate.win *)",
      "Bash(~/tools/delegate-report *)",
      "Bash(touch ~/.local/share/mimo-auto.flag)",
